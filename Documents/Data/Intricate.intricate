      "y": 9976.236756990087,
      "width": 258.0,
      "height": 31.0,
      "z_value": -9.343000000000364,
      "ports_visible": false,
      "shelf_visible": false,
      "label": "Node Cleanup Compliance",
      "depth_front": false,
      "node_tint": ""
    },
    {
      "node_id": 0,
      "node_type": "image",
      "title": "Image",
      "uuid": "4729a0ababc04a67b53ac7d0559dd56e",
