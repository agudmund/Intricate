    {
      "node_id": 0,
      "node_type": "warm",
      "title": "",
      "uuid": "5a2b8378904e44e2973c0a8cc7e3520b",
      "x": 89537.02026958203,
      "y": 26541.887633176968,
      "width": 300.0,
      "height": 212.0,
      "z_value": -9.146000000000473,
      "ports_visible": false,
      "shelf_visible": true,
      "body_text": "- graphics/Particles.py _tick_timer \u2014 _FadingParticle._update() already catches RuntimeError on dead scene/item access and self-kills. Uses flush_scene before any bulk removal. This is the reference implementation for other per-frame mutators.\n- nodes/Port.py \u2014 no timers, no animations.\n- nodes/NodeButton.py::EmojiButton \u2014 no timer or signal into the node graph."
    },
    {
      "node_id": 0,
      "node_type": "warm",
      "title": "",
      "uuid": "04a58179b0f043b5a3ba634666e13587",
      "x": 78571.58416263013,
