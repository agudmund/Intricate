      "y": 3136.7356849677863,
      "width": 400.0,
      "height": 400.0,
      "z_value": 100.0,
      "ports_visible": false,
      "shelf_visible": true,
      "pinned": false,
      "pin_vp_x": 0.0,
      "pin_vp_y": 0.0,
      "pin_scale": 1.0,
      "cache_key": "6243e87c62e170d6c297427a8ed6f551e9d5bcd690565fd0d012de705d447b17.png",
      "source_path": "C:\\Users\\thisg\\Desktop\\Iconic\\Images\\Stickers\\Intricate\\Return.png",
      "source_size": 62370,
      "source_mtime": 1777939229.8137798,
