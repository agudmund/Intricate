    },
    {
      "node_id": 0,
      "node_type": "warm",
      "title": "Bright Tomorrow",
      "uuid": "0937893a5bb74bbeb318fc72d5a10c9d",
      "x": 1072.7121859189251,
      "y": 2865.0349954312087,
