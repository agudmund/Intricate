    {
      "node_id": 0,
      "node_type": "claude_response",
      "title": "Response",
      "uuid": "ae5e9fc9bc824a209d60fa848bba035a",
      "x": 22688.065313428513,
      "y": 3260.0023109172935,
      "width": 420.0,
      "height": 344.0,
      "z_value": -9.695000000000169,
      "ports_visible": false,
      "shelf_visible": true,
      "label": "The button row is positioned at `r.top() + 4` by BaseNode. I can't move that for all nodes \u2014 just for ClaudeResponseNode. The cleanest approach: override `_position_buttons` in ClaudeResponseNode to push the buttons down by the emoji height, and paint the emoji in the freed-up top-left space.",
      "depth_front": false,
      "node_tint": ""
    },
    {
      "node_id": 0,
      "node_type": "about",
      "title": "Retrospective on the ordering story.",
      "uuid": "9be9e79178aa47b1965a7791d980ae88",
      "x": 78431.26340947945,
      "y": 20905.00012221083,
      "width": 388.0,
      "height": 31.0,
      "z_value": -9.197000000000445,
      "ports_visible": false,
      "shelf_visible": false,
      "label": "Retrospective on the ordering story.",
      "depth_front": false,
      "node_tint": ""
    },
    {
      "node_id": 0,
      "node_type": "warm",
      "title": "",
      "uuid": "a841b36076a8456794813f04f9be6d45",
      "x": 30812.960209355133,
      "y": 8288.161995823832,
      "width": 300.0,
      "height": 200.0,
      "z_value": -9.599000000000222,
      "ports_visible": false,
      "shelf_visible": true,
      "body_text": "High gain / low effort / short time \u2014 execute first. These are the sanitization wins that build momentum and free up capacity for harder fixes.\nHigh gain / high effort / long time \u2014 schedule and resource deliberately. These are the structural fixes; they need to be started early because of their duration, even if their payoff comes later.\nLow gain / low effort \u2014 opportunistic. Fold into adjacent work; don't dedicate sequence slots.\nLow gain / high effort \u2014 defer or discard unless they unblock a high-gain fix downstream.\nWhy time changes the order of operations"
    },
    {
      "node_id": 0,
      "node_type": "warm",
      "title": "Secondary audit sweep (same day, after a second 0xC0000409 at 11:53:21)",
      "uuid": "daf9446e37834e7986a2ad3fae2d548e",
      "x": 92654.33409982473,
      "y": 29025.32500638524,
      "width": 738.0,
      "height": 128.0,
      "z_value": -9.129000000000483,
      "ports_visible": false,
      "shelf_visible": true,
      "body_text": "A second Event Viewer crash with the same signature appeared within the same working session, triggered from a different orphan timer than HealthNode.  Rather than chase each instance reactively, the guard was extracted as a shared helper on BaseNode (_timer_slot_alive(timer_attr)) and applied to every dashboard-style node that uses the orphan-timer pattern:"
    },
