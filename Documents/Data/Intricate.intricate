    {
      "node_id": 0,
      "node_type": "about",
      "title": "Is this what you call caring these days?",
      "uuid": "5e304019340d420bb705b89596e45a8e",
      "x": 8521.834631129932,
      "y": 6663.705108062516,
      "width": 439.20004280918283,
