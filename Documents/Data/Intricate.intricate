      "node_type": "about",
      "title": "The Five",
      "uuid": "342e0e8b620c4581b3bd3a0c36c00908",
      "x": 11093.817234366663,
      "y": 1005.0921770312921,
      "width": 108.0,
      "height": 31.0,
      "z_value": -9.98100000000001,
      "ports_visible": false,
      "shelf_visible": false,
