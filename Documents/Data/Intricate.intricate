    {
      "node_id": 0,
      "node_type": "about",
      "title": "Note",
      "uuid": "314a41dcf09e45768b4ca615ed923fc7",
      "x": 13961.804379156087,
      "y": 5135.369457283661,
      "width": 108.0,
