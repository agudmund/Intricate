      "title": "Note",
      "uuid": "7be5a950995b47bc852aefd71ad774f2",
      "x": 2631.275932909139,
      "y": 3898.8970166746767,
      "width": 148.0,
      "height": 31.0,
      "z_value": -9.826000000000096,
      "ports_visible": false,
      "shelf_visible": false,
