      "depth_front": false
    },
    {
      "node_id": 0,
      "node_type": "warm",
      "title": "And then we know",
      "uuid": "d16783f2724b4cc8acad5a0d36792d55",
      "x": 33341.8993019602,
      "y": 12863.517977295229,
      "width": 288.5713211708935,
      "height": 142.80581840918603,
      "z_value": -9.579000000000233,
      "ports_visible": false,
      "shelf_visible": true,
      "body_text": "If it's actually worth applying our actual more elaborate thoughts to it, \nby running this reasoning chain per thought across the entire value chain per node"
    },
    {
      "node_id": 0,
      "node_type": "warm",
      "title": "Macroeconomic singleton analysis",
      "uuid": "198c9272c31647c09a1dc1f745fca649",
