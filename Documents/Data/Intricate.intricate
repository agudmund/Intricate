    {
      "node_id": 0,
      "node_type": "warm",
      "title": "Daemon worker thread race",
      "uuid": "9d478b4ab95d46c4b89c1c832e98c078",
      "x": 56553.90398583627,
      "y": 13321.709936844622,
      "width": 300.0,
      "height": 156.0,
      "z_value": -9.29500000000039,
      "ports_visible": false,
      "shelf_visible": true,
      "body_text": "the background markdown\u2192HTML thread could finish and write to self._pending_html after teardown had already nulled the proxy and editor. The delivery timer callback would then try to call setHtml() on a dead widget."
    },
    {
      "node_id": 0,
      "node_type": "image",
      "title": "Image",
      "uuid": "4f9967d8b65a4a73a9ffb9960332fb12",
      "x": 16189.905813610694,
      "y": 8200.098739743686,
      "width": 436.7248159853334,
      "height": 698.1580577932709,
      "z_value": -9.970000000000017,
      "ports_visible": false,
      "shelf_visible": false,
      "image_b64": "",
      "cache_key": "44f2cddb49ae75d97053f468bde0bb7030a9ddbb5568de875a500eeccbf8aa59.jpg",
      "caption": "2022-03-16 15.03.03",
      "source_path": "C:\\Users\\thisg\\Desktop\\Cloning Humans\\Images\\2022-03-16 15.03.03.jpg",
      "source_size": 271945,
      "source_mtime": 1769551590.6615517,
