      "ports_visible": false,
      "shelf_visible": true,
      "label": "Good \u2014 `_run_vision` is only reachable via `_vision_rename` (eye button) and `_trigger_vision`. Let me check where `_trigger_vision` itself is called:",
      "depth_front": false,
      "node_tint": "#5a6a5a"
    },
    {
