      "height": 243.36160303792303,
      "z_value": -9.972000000000016,
      "ports_visible": false,
      "shelf_visible": false,
      "image_b64": "",
      "cache_key": "1100873e83426ef566a6f4bc3b9c2fb91b616528d9efa74470039b1e17687b7f.jpg",
      "caption": "origin",
