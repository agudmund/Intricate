    {
      "node_id": 0,
      "node_type": "warm",
      "title": "Concern and Resolution",
      "uuid": "a9382e3cd4d7483fa869081e7ef70642",
      "x": 87613.47104243272,
      "y": 24437.65280207165,
      "width": 300.0,
      "height": 240.0,
      "z_value": -9.158000000000467,
      "ports_visible": false,
      "shelf_visible": true,
      "body_text": "Removal speed Unchanged. Quieting is a local disconnect, invalidate is a rect push.\nLive UI freezes None. Invalidate is async \u2014 Qt batches it with the next paint.\nMissed final-state paint None. The invalidate triggers one guaranteed repaint of the ghost region.\nUnpinned StickerNodes _disconnect_viewport_tracking early-returns if _pin_connected is False, so the hook is free for the common case."
    },
