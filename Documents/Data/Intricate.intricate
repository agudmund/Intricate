    {
      "node_id": 0,
      "node_type": "about",
      "title": "Background Color",
      "uuid": "1e1493be2cf143e18ddc47d28edf05eb",
      "x": 42774.290032725294,
      "y": 8159.96411547149,
      "width": 188.0,
      "height": 31.0,
      "z_value": -9.36800000000035,
      "ports_visible": false,
      "shelf_visible": false,
