    {
      "node_id": 0,
      "node_type": "warm",
      "title": "We run Massive",
      "uuid": "f3326cf0bbe6416ba9a46679121e0941",
      "x": 14017.514566655356,
      "y": 8536.848071550647,
      "width": 330.3244188114779,
      "height": 248.0,
      "z_value": -9.958000000000023,
      "ports_visible": false,
      "shelf_visible": true,
      "body_text": "But this was different\nA societal collapse thing\n\nA mission to get across the city that was in ruins\nGet some materials and stop the bad guy\n\nSuper fun, won the game and woke up.\nBut it reminded me of a clash\nBetween Hunger Games and the City of Lost Children\nIn a Strange day setting..."
    },
    {
      "node_id": 0,
      "node_type": "warm",
      "title": "Bright Tomorrow",
      "uuid": "530b758803c94ab8a177c31f040247ce",
      "x": 14462.505783096378,
      "y": 9373.172328090002,
      "width": 302.1636852114443,
      "height": 190.9840910072685,
      "z_value": -9.960000000000022,
      "ports_visible": false,
      "shelf_visible": true,
      "body_text": "Not really sure what the other guys where up to\nI just know I did great!\n\nSo strange, massive\n\nLooked great though."
    },
