    {
      "node_id": 0,
      "node_type": "about",
      "title": "Note",
      "uuid": "efa75e4250e04b2d9b42ad00869de6db",
      "x": 16345.623723037614,
      "y": 4364.912729845154,
      "width": 646.0,
      "height": 52.0,
      "z_value": -9.684000000000175,
      "ports_visible": false,
