      "title": "Sleepy kitten Coco",
      "uuid": "cb610317e76a4581954422f74b15ccd0",
      "x": 15805.409389427234,
      "y": 8359.972655565354,
      "width": 219.28027558469284,
      "height": 32.08692282006541,
      "z_value": 10.0,
