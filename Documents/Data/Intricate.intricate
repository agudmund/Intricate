    {
      "node_id": 0,
      "node_type": "about",
      "title": "We anchor ourselves into the past",
      "uuid": "e126792030fb4a5abf7b9bacac9b91f5",
      "x": -326.9522883482002,
      "y": -520.973287236033,
      "width": 358.0,
      "height": 31.0,
      "z_value": -9.957000000000024,
