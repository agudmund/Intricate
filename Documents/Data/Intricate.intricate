    {
      "node_id": 0,
      "node_type": "image",
      "title": "Image",
      "uuid": "167f11230e634740a392e9debb526c3a",
      "x": 12837.26685456308,
      "y": 8886.885281654077,
      "width": 663.9643687798432,
      "height": 670.2704501064773,
      "z_value": -9.956000000000024,
      "ports_visible": false,
      "shelf_visible": false,
      "image_b64": "",
