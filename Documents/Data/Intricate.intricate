    {
      "node_id": 0,
      "node_type": "warm",
      "title": "Endless Potential",
      "uuid": "45f59774659640d0b26b514279fdb4e7",
      "x": 51140.238911613436,
      "y": -2784.4925083717694,
      "width": 300.0,
