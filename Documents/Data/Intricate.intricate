    {
      "node_id": 0,
      "node_type": "about",
      "title": "The self healing just gave it an immune system",
      "uuid": "6918b6d59f834db3bf85a6034d3f3898",
      "x": 2169.41819190233,
      "y": 5212.821688266228,
      "width": 488.5625,
