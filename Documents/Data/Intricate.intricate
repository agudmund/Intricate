      "shelf_visible": false,
      "label": "Left foot, right foot, left foot, right foot",
      "depth_front": false,
      "node_tint": ""
    },
    {
      "node_id": 0,
      "node_type": "about",
      "title": "Left foot, right foot, left foot, right foot",
      "uuid": "4dcf023e3f514e548493b444bb964026",
      "x": 5895.760789566094,
      "y": 2304.5862891578668,
      "width": 468.0,
      "height": 29.0,
      "z_value": -9.655000000000191,
      "ports_visible": false,
      "shelf_visible": false,
