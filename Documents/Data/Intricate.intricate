    {
      "node_id": 0,
      "node_type": "warm",
      "title": "Step, What, and Why",
      "uuid": "196be2351e2744e293df00799529db72",
      "x": 74166.04076328602,
      "y": 20582.422018629935,
      "width": 300.0,
