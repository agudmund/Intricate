    {
      "node_id": 0,
      "node_type": "about",
      "title": "April 16th 2026: Codebase-wide proxy + t",
      "uuid": "4a0e0dc244dd46e9a7eb91c0d0b4bd94",
      "x": 89958.43367099964,
      "y": 26643.022027508356,
      "width": 528.0,
