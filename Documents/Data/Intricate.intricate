    {
      "node_id": 0,
      "node_type": "about",
      "title": "Phase 3: Cross-thread timer delivery + p",
      "uuid": "a86a8467166b4ac5897fc4614aacc0f4",
      "x": 66541.15061492413,
      "y": 17201.23089207668,
      "width": 648.0,
