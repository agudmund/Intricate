    {
      "node_id": 0,
      "node_type": "warm",
      "title": "Gentle",
      "uuid": "9e3b13a40a1a4c91ad25304dc80749f3",
      "x": 45727.21979626498,
      "y": 48494.57568622146,
      "width": 300.0,
