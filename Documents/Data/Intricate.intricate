    {
      "node_id": 0,
      "node_type": "about",
      "title": "We need to start setting up The Settlers Taskbar daemon",
      "uuid": "bb007122be6e453092f7c751869a6cca",
      "x": 16317.722955372341,
      "y": -3163.397319348068,
      "width": 601.1286470738423,
