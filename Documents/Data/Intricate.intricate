    },
    {
      "node_id": 0,
      "node_type": "warm",
      "title": "Tiny little extra sprinkles of joy",
      "uuid": "2171b80bcf07426daa12d090630e97be",
      "x": 49810.50430903034,
      "y": 48734.80786250205,
      "width": 370.0,
