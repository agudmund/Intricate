    {
      "node_id": 0,
      "node_type": "about",
      "title": "-Best TV ever",
      "uuid": "5f3165c3e13541aa9d8a6cd25c4e36d4",
      "x": 670.2256480928947,
      "y": 2775.7727847444967,
      "width": 158.0,
      "height": 31.0,
      "z_value": -9.952000000000027,
