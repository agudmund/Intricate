      "body_text": "Three categories fall out naturally:"
    },
    {
      "node_id": 0,
      "node_type": "warm",
      "title": "",
      "uuid": "ff740e5e201f4792a8d4054557649514",
      "x": 53092.76347365945,
      "y": 30124.72799293683,
      "width": 300.0,
