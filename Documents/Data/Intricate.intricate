    {
      "node_id": 0,
      "node_type": "warm",
      "title": "",
      "uuid": "0b31c327ab9b43298e6a5b9da31993a3",
      "x": 31379.68408646375,
      "y": 10906.380770363845,
      "width": 300.0,
