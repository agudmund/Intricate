    {
      "node_id": 0,
      "node_type": "warm",
      "title": "Lesson",
      "uuid": "60634c14014a4264bfaa40d8c3c1f089",
      "x": 48568.65367176199,
      "y": 10592.497304759267,
      "width": 300.0,
      "height": 184.0,
      "z_value": -9.325000000000374,
      "ports_visible": false,
      "shelf_visible": true,
      "body_text": "When a fix lands on a subclass to address a class of race condition that the parent class enables, the fix belongs on the parent. StickerNode's _quiet_for_shake was correct in shape but wrong in location \u2014 every future chromeless descendant would have had to remember to add it, and JoyStats and Value didn't."
    },
