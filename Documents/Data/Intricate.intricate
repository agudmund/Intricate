    {
      "node_id": 0,
      "node_type": "about",
      "title": "Iconic Housekeeping",
      "uuid": "b702ed2c2716459dbcd2eeade40bcf57",
      "x": 14084.661154878573,
      "y": 5136.5447496280485,
      "width": 310.8616594692969,
      "height": 49.77578702546043,
      "z_value": -9.991000000000005,
