    {
      "node_id": 0,
      "node_type": "about",
      "title": "Some targeted Changes",
      "uuid": "878039f330434131926674087c8ae4fb",
      "x": 16504.146779207735,
      "y": 3181.3195914814096,
      "width": 248.76344855985303,
