      "z_value": -9.756000000000135,
      "ports_visible": false,
      "shelf_visible": true,
      "label": "This node hasn't decided what it wants to say yet so it just kinda hangs out enjoying the whole spectacle without making a fuzz about it and decided a long time ago to just jump into the conversation when that moment presents itself.",
