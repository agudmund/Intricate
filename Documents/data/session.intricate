      "width": 420.0,
      "height": 288.0,
      "z_value": -10.0,
      "ports_visible": false,
      "shelf_visible": true,
      "label": "The `emoji` field stays on the dataclass (so the node can read it at paint time) but never enters `to_dict()` and is never read from `from_dict()`. Every app launch, every node gets a fresh roll from the pool. The graph breathes.",
      "depth_front": false,
      "node_tint": "#5a6a5a"
    },
    {
      "node_id": 0,
      "node_type": "claude_response",
      "title": "Response",
      "uuid": "c59b92933a8f4628801e3d562c04314a",
      "x": 16352.832550228468,
      "y": 522.717902365981,
      "width": 420.0,
      "height": 148.0,
      "z_value": -9.690000000000172,
      "ports_visible": false,
      "shelf_visible": true,
      "label": "2px from the left edge \u2014 mirrors the right-side spacing it had before.",
      "depth_front": false,
      "node_tint": ""
    },
    {
      "node_id": 0,
      "node_type": "claude_response",
      "title": "Response",
      "uuid": "99aacf6ac2a14f8380f8d1bc163ae614",
      "x": 14929.059623976671,
      "y": 1151.402819300797,
      "width": 420.0,
      "height": 148.0,
      "z_value": -9.687000000000173,
      "ports_visible": false,
      "shelf_visible": true,
      "label": "The height calculation doesn't account for `_EMOJI_ROW_H`:",
      "depth_front": false,
      "node_tint": ""
    },
    {
      "node_id": 0,
      "node_type": "claude_response",
      "title": "Response",
